rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null && request.auth.token.email is string;
    }

    function email() {
      return request.auth.token.email.lower();
    }

    function isAdminEmail() {
      return isSignedIn() && email() == 'gu.correa98@gmail.com';
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAdminEmail() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && userDoc().role == 'admin');
    }

    function isAllowedCollaborator() {
      return isSignedIn() && exists(/databases/$(database)/documents/allowedUsers/$(email())) && get(/databases/$(database)/documents/allowedUsers/$(email())).data.active == true;
    }

    function canAccessApp() {
      return isAdmin() || isAllowedCollaborator();
    }

    function isOwnVisibleActivity(data) {
      return canAccessApp() && data.ownerEmail == email() && data.status != 'Backlog';
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.email == email()
        && request.resource.data.active == true
        && (
          (isAdminEmail() && request.resource.data.role == 'admin') ||
          (isAllowedCollaborator() && request.resource.data.role == 'collaborator')
        );
      allow delete: if isAdmin() || isOwnVisibleActivity(resource.data);
    }

    match /allowedUsers/{userEmail} {
      allow read: if isAdmin() || (isSignedIn() && userEmail == email());
      allow create, update, delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if isAdmin() || isOwnVisibleActivity(resource.data);
      allow create: if isAdmin() || isOwnVisibleActivity(request.resource.data);
      allow update: if isAdmin() || (isOwnVisibleActivity(resource.data) && isOwnVisibleActivity(request.resource.data));
      allow delete: if isAdmin();
    }

    match /teamMembers/{memberId} {
      allow read: if canAccessApp();
      allow write: if isAdmin();
    }

    match /financeExpenses/{expenseId} {
      allow read, write: if isAdmin();
    }
  }
}
