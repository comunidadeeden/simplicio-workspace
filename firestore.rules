rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; 
    }
    
    // Core Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // Admin helper
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }

    match /users/{userId} {
      // Allow read only to owner or admin
      allow read: if isValidId(userId) && isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // We'll manage user creation via admin SDK or strict rules later. Right now we isolate this to false to ensure safety in MVP.
      allow write: if false;
    }

    match /activities/{activityId} {
      allow read, write: if true;
    }

    match /teamMembers/{memberId} {
      allow read, write: if true;
    }

    match /financeExpenses/{expenseId} {
      allow read, write: if true;
    }
  }
}
